---
import type { RenderedMarkdown, TocNode } from "../lib/markdown";
import ReportTocItem from "./ReportTocItem.astro";

interface Props {
  versionId: string;
  markdown: RenderedMarkdown;
}

const { versionId, markdown } = Astro.props;
const safeId = versionId.replace(/[^a-zA-Z0-9-]/g, "-");
const panelId = `complete-report-${safeId}`;
const buttonId = `complete-report-toggle-${safeId}`;
const tocTree: TocNode[] = [];
const tocStack: TocNode[] = [];

for (const item of markdown.toc) {
  while (tocStack.length > 0 && tocStack[tocStack.length - 1].depth >= item.depth) {
    tocStack.pop();
  }

  const node: TocNode = { ...item, children: [] };
  const parent = tocStack[tocStack.length - 1];
  if (parent) parent.children.push(node);
  else tocTree.push(node);
  tocStack.push(node);
}
---

<section
  class="complete-report"
  aria-labelledby={`complete-report-title-${safeId}`}
  data-complete-report
>
  <header>
    <p>原始长文</p>
    <h2 id={`complete-report-title-${safeId}`}>完整报告</h2>
    <button
      id={buttonId}
      type="button"
      aria-controls={panelId}
      aria-expanded="false"
      data-report-toggle
    >
      展开完整报告
    </button>
  </header>

  <nav aria-label="完整报告目录">
    <h3>报告目录</h3>
    <ol class="report-toc-tree">
      {tocTree.map((node, index) => (
        <ReportTocItem node={node} path={String(index)} reportId={safeId} />
      ))}
    </ol>
  </nav>

  <div id={panelId} class="markdown-body" hidden set:html={markdown.html} />
</section>

<script>
  for (const container of document.querySelectorAll<HTMLElement>("[data-complete-report]")) {
    const button = container.querySelector<HTMLButtonElement>("[data-report-toggle]");
    const panelId = button?.getAttribute("aria-controls");
    const panel = panelId ? document.getElementById(panelId) : null;
    if (!(panel instanceof HTMLElement) || !(button instanceof HTMLButtonElement)) continue;
    const reportPanel = panel;
    const toggleButton = button;

    function setExpanded(expanded: boolean) {
      reportPanel.hidden = !expanded;
      toggleButton.setAttribute("aria-expanded", String(expanded));
      toggleButton.textContent = expanded ? "折叠完整报告" : "展开完整报告";
    }

    toggleButton.addEventListener("click", () => {
      setExpanded(toggleButton.getAttribute("aria-expanded") !== "true");
    });

    for (const tocToggle of container.querySelectorAll<HTMLButtonElement>("[data-toc-toggle]")) {
      const groupId = tocToggle.getAttribute("aria-controls");
      const group = groupId ? document.getElementById(groupId) : null;
      const label = tocToggle.dataset.tocLabel;
      if (!(group instanceof HTMLOListElement) || !label) continue;

      tocToggle.addEventListener("click", () => {
        const expanded = tocToggle.getAttribute("aria-expanded") !== "true";
        group.hidden = !expanded;
        tocToggle.setAttribute("aria-expanded", String(expanded));
        tocToggle.setAttribute("aria-label", `${expanded ? "收起" : "展开"}“${label}”的下一级`);
        tocToggle.title = `${expanded ? "收起" : "展开"}下一级`;
      });
    }

    for (const anchor of container.querySelectorAll<HTMLAnchorElement>(
      `[data-report-anchor][href^="#"]`
    )) {
      anchor.addEventListener("click", (event) => {
        const href = anchor.getAttribute("href");
        if (!href) return;
        const target = document.getElementById(decodeURIComponent(href.slice(1)));
        if (!(target instanceof HTMLElement)) return;
        event.preventDefault();
        setExpanded(true);
        target.setAttribute("tabindex", "-1");
        target.focus({ preventScroll: true });
        target.scrollIntoView({ block: "start", behavior: "smooth" });
        history.replaceState(null, "", href);
      });
    }
  }
</script>
